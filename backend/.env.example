APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Публичный URL (https://домен) — в Docker задаётся через compose/.env корня проекта
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL. В Docker имя хоста = сервис compose «postgres», не 127.0.0.1.
# Без Docker на той же машине: DB_HOST=127.0.0.1
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=library_catalog
DB_USERNAME=library_user
DB_PASSWORD=library_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Почта (REG.RU и др.): хост/порт из панели (часто smtp.hosting.reg.ru или IP SMTP). Пароль только в .env.
MAIL_MAILER=smtp
MAIL_HOST=smtp.hosting.reg.ru
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=20
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"
# Часто: MAIL_PORT=465, MAIL_ENCRYPTION=ssl

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# JWT (tymon/jwt-auth): выполните php artisan jwt:secret или задайте JWT_SECRET в docker-compose.
# Не добавляйте в корневой .env compose строку JWT_SECRET= с пустым значением — иначе секрет не подхватится из backend/.env.
