# Скопируйте в файл `.env` в этом же каталоге (рядом с docker-compose.yml).
# Docker Compose подставит переменные в контейнеры.

# Публичный URL приложения со схемой (для Laravel: ссылки, корректная схема за reverse proxy)
APP_URL=http://catalogbooks.ru

# URL API, который видит браузер:
# — рекомендуется относительный путь, если фронт и API отдаются с одного хоста (Nginx → webface + /api → backend):
NEXT_PUBLIC_API_URL=/api
# — или полный URL, если фронт и API на разных origin:
# NEXT_PUBLIC_API_URL=https://your-domain.example/api

# Домены фронта для Sanctum (без https://), через запятую
SANCTUM_STATEFUL_DOMAINS=catalogbooks.ru,www.catalogbooks.ru

# Секрет JWT для backend: не короче 32 символов (требование HS256 / Lcobucci). Смените в продакшене.
# Не задавайте JWT_SECRET= с пустым значением.
JWT_SECRET=LibraryCatalog_dev_jwt_hmac_key_at_least_32_bytes_long_ok
